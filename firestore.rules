rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - User ID of the scanner
    //   - productName: string (required) - Name of the product
    //   - imageUrl: string (optional) - Image data or URL
    //   - timestamp: timestamp (required) - When scanned
    //   - analysis: map (required) - AI analysis results
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidScan(data) {
      return data.uid is string &&
             data.productName is string && data.productName.size() > 0 && data.productName.size() < 200 &&
             data.timestamp is timestamp &&
             data.analysis is map;
    }

    match /scans/{scanId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidScan(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if false; // Scans are immutable for now
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aryankewat996@gmail.com" && request.auth.token.email_verified == true));
    }
  }
}
